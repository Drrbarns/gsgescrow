# Backend Environment Variables
SUPABASE_URL=https://supabase.yourdomain.com
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
PAYMENT_PROVIDER=moolre
MOOLRE_API_USER=your_moolre_username
MOOLRE_API_PUBKEY=your_moolre_public_key
MOOLRE_ACCOUNT_NUMBER=your_moolre_account_number
MOOLRE_BUSINESS_EMAIL=billing@yourdomain.com
MOOLRE_API_VASKEY=your_moolre_vaskey
MOOLRE_SMS_SENDER_ID=YourApprovedSenderID
# Optional scenario key for test simulation (e.g. ASMS07, AIN01)
# MOOLRE_SMS_SCENARIO_KEY=

# Optional fallback provider
PAYSTACK_SECRET_KEY=sk_test_xxxxx
REDIS_URL=redis://localhost:6379
APP_URL=https://sellbuysafe.gsgbrands.com
CORS_ORIGINS=https://sellbuysafe.gsgbrands.com
NODE_ENV=development
PORT=4000

# Observability
# Optional: if omitted, telemetry remains local logs only
SENTRY_DSN=
SENTRY_ENV=production
OPS_ALERT_MIN_INTERVAL_SEC=300
OPS_PAYOUT_FAILURE_THRESHOLD_1H=3
OPS_SMS_FAILURE_RATIO_THRESHOLD_PCT=25
OPS_SCHEDULER_DRIFT_THRESHOLD_SEC=1200

# Simulation mode: no real PSP payments/payouts (for testing full flow)
# SIMULATION_MODE=true
