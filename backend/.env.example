# Backend Environment Variables
SUPABASE_URL=https://supabase.yourdomain.com
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
PAYMENT_PROVIDER=moolre
MOOLRE_API_USER=your_moolre_username
MOOLRE_API_PUBKEY=your_moolre_public_key
MOOLRE_ACCOUNT_NUMBER=your_moolre_account_number
MOOLRE_BUSINESS_EMAIL=billing@yourdomain.com

# Optional fallback provider
PAYSTACK_SECRET_KEY=sk_test_xxxxx
REDIS_URL=redis://localhost:6379
APP_URL=https://sellbuysafe.gsgbrands.com
CORS_ORIGINS=https://sellbuysafe.gsgbrands.com
NODE_ENV=development
PORT=4000

# Simulation mode: no real PSP payments/payouts (for testing full flow)
# SIMULATION_MODE=true
