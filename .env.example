# ============================================================
# Sell-Safe Buy-Safe — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- Supabase (your self-hosted instance) ---
SUPABASE_URL=https://supabase.yourdomain.com
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Frontend (public, baked into build) ---
NEXT_PUBLIC_SUPABASE_URL=https://supabase.yourdomain.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://sellbuysafe.gsgbrands.com
NEXT_PUBLIC_API_URL=https://api.sellbuysafe.gsgbrands.com
# Optional comma-separated API host fallbacks used by frontend runtime if primary fails
NEXT_PUBLIC_API_FALLBACK_URLS=https://api.sellbuysafe.gsgbrands.com.gh,https://api.sellbuysafe.com

# --- Payment Provider ---
PAYMENT_PROVIDER=moolre
MOOLRE_API_USER=your_moolre_username
MOOLRE_API_PUBKEY=your_moolre_public_key
MOOLRE_ACCOUNT_NUMBER=your_moolre_account_number
MOOLRE_BUSINESS_EMAIL=billing@yourdomain.com
MOOLRE_API_VASKEY=your_moolre_vaskey
MOOLRE_SMS_SENDER_ID=YourApprovedSenderID
# Optional scenario key for test simulation (e.g. ASMS07, AIN01)
# MOOLRE_SMS_SCENARIO_KEY=

# Optional fallback provider
PAYSTACK_SECRET_KEY=sk_live_xxxxx
API_PUBLIC_URL=https://api.sellbuysafe.gsgbrands.com

# --- Redis (auto-configured in docker-compose) ---
REDIS_URL=redis://redis:6379

# --- Observability (backend) ---
SENTRY_DSN=
SENTRY_ENV=production
OPS_ALERT_MIN_INTERVAL_SEC=300
OPS_PAYOUT_FAILURE_THRESHOLD_1H=3
OPS_SMS_FAILURE_RATIO_THRESHOLD_PCT=25
OPS_SCHEDULER_DRIFT_THRESHOLD_SEC=1200
