# ============================================================
# Sell-Safe Buy-Safe — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- Supabase (your self-hosted instance) ---
SUPABASE_URL=https://supabase.yourdomain.com
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Frontend (public, baked into build) ---
NEXT_PUBLIC_SUPABASE_URL=https://supabase.yourdomain.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://sellbuysafe.gsgbrands.com
NEXT_PUBLIC_API_URL=https://sellbuysafe.gsgbrands.com

# --- Paystack ---
PAYSTACK_SECRET_KEY=sk_live_xxxxx

# --- Redis (auto-configured in docker-compose) ---
REDIS_URL=redis://redis:6379
